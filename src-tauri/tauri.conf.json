{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Win-Top",
    "version": "0.1.3"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.wintop.app",
      "icon": ["icons/icon.ico", "icons/icon.png"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Win-Top",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ]
  }
}
